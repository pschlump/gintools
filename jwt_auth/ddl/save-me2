						and exists (
							select 'found'
							from q_qr_users as t2
							where t2.user_id = t1.parent_user_id
							  and ( t1.start_date < current_timestamp or t1.start_date is null )
							  and ( t1.end_date > current_timestamp or t1.end_date is null )
							  and t2.email_verified = 'y'
