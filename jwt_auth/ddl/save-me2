create or replace function q_auth_v1_register_token ( p_parent_user_id int,  p_hmac_password varchar,  p_userdata_password varchar )
	returns text
	as $$
DECLARE
	l_data					text;
	l_fail					bool;
	l_user_id				int;
	l_bad_user_id			int;
	l_debug_on 				bool;
	l_pw					text;
	l_un					text;
	l_2fa_id				uuid;
	l_email_verified		varchar(1);
	l_start_date			timestamp;
	l_end_date				timestamp;
	l_privilages			jsonb;
	l_failed_login_timeout 	timestamp;
	l_login_failures 		int;
	l_real_name				text;
	l_auth_token			uuid;
BEGIN
	l_debug_on = q_get_config_bool ( 'debug' );

	-- Copyright (C) Philip Schlump, 2008-2021.
	-- BSD 3 Clause Licensed.  See LICENSE.bsd
	-- version: 75416ab6e8f63710cf7b3dc74043b25d952a88d1 tag: v1.0.6 build_date: Mon Mar 21 05:08:36 MDT 2022
	l_fail = false;
	l_data = '{"status":"unknown"}';

	if l_debug_on then
		insert into t_output ( msg ) values ( '->'||p_userdata_password||'<-');
	end if;

	l_un = encode(digest(uuid_generate_v4()::text, 'sha256'), 'base64');
	l_pw = encode(digest(uuid_generate_v4()::text, 'sha256'), 'base64');

	-- Cleanup any users that have expired tokens.
	delete from q_qr_users
		where email_verify_expire < current_timestamp - interval '30 days'
		  and email_verify_token is not null
		  and email_verified = 'n'
		;

	-- Cleanup old auth tokens.
	delete from q_qr_auth_tokens 
		where expires < current_timestamp
		;

	if not l_fail then
		select
			  user_id
			, email_verified
			, start_date
			, end_date
			, privilages
		    , pgp_sym_decrypt(real_name_enc,p_userdata_password)::text
			, failed_login_timeout 	
			, login_failures 		
		into
			  l_user_id
			, l_email_verified
			, l_start_date
			, l_end_date
			, l_privilages
			, l_real_name
			, l_failed_login_timeout 	
			, l_login_failures 	
		from q_qr_users
		where user_id = p_parent_user_id
			and account_type = 'login'
		;
		if not found then
			l_fail = true;
			l_data = '{"status":"error","msg":"Invalid Username or Password","code":"0001","location":"001.tables.m4.sql 1982"}'; -- return no such account or password
			insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Invalid Username or Password', '0001', 'File:001.tables.m4.sql Line No:1983');
		end if;
	end if;

	if l_debug_on then
		insert into t_output ( msg ) values ( '->'||p_userdata_password||'<-');
		insert into t_output ( msg ) values ( 'l_real_name = ->'||l_real_name||'<-');
		--select pgp_sym_decrypt(l_real_name::bytea,p_userdata_password)::text
		--	into l_tmp;
		--insert into t_output ( msg ) values ( 'l_tmp = ->'||l_tmp||'<-');
	end if;

	if not l_fail then
		if l_email_verified = 'n' then
			l_fail = true;
			l_data = '{"status":"error","msg":"Account has not not been verified","code":"0002","location":"001.tables.m4.sql 1998"}';
			insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Account has not been verified', '0002', 'File:001.tables.m4.sql Line No:1999');
		end if;
	end if;
	if not l_fail then
		if l_start_date is not null then
			if l_start_date > current_timestamp then
				l_fail = true;
				l_data = '{"status":"error","msg":"Account has a start date that has not been reached","code":"0003","location":"001.tables.m4.sql 2006"}';
			insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Account has start date that has not bee reached', '0003', 'File:001.tables.m4.sql Line No:2007');
			end if;
		end if;
	end if;
	if not l_fail then
		if l_end_date is not null then
			if l_end_date <= current_timestamp then
				l_fail = true;
				l_data = '{"status":"error","msg":"Account has a end date that has been reached","code":"0004","location":"001.tables.m4.sql 2015"}';
				insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Account has ned date that has bee reached', '0004', 'File:001.tables.m4.sql Line No:2016');
			end if;
		end if;
	end if;

	if not l_fail then
		if l_require_2fa = 'n' then
			-- insert / create auth_token
			l_auth_token = uuid_generate_v4();
			BEGIN
				insert into q_qr_auth_tokens ( token, user_id ) values ( l_auth_token, l_user_id );
			EXCEPTION WHEN unique_violation THEN
				l_fail = true;
				l_data = '{"status":"error","msg":"Unable to create user/auth-token.","code":"0005","location":"001.tables.m4.sql 2029"}';
				insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Unable to crate user/auth-token.', '0005', 'File:001.tables.m4.sql Line No:2030');
			END;
		end if;
	end if;
	if not l_fail then
		if l_login_failures > 6 or l_failed_login_timeout >= current_timestamp then
			l_fail = true;
			l_data = '{"status":"error","msg":"Too many failed login attempts - please wait 1 minute.","code":"0006","location":"001.tables.m4.sql 2037"}';
			insert into q_qr_auth_log ( user_id, activity, code, location ) values ( l_user_id, 'Too many failed login attempts - please wait 1 minute.', '0006', 'File:001.tables.m4.sql Line No:2038');
			update q_qr_users
				set failed_login_timeout = current_timestamp + interval '1 minute'
				where user_id = l_user_id
				  and failed_login_timeout is null
				;
		end if;
	end if;

	if not l_fail then
		INSERT INTO q_qr_users (
			  email_hmac
			, password_hash
			, real_name_enc
			, parent_user_id
			, account_type
			, email_verified		
		) VALUES (
			  encode(hmac(l_un, p_hmac_password, 'sha256'), 'base64')
			, crypt(l_pw, gen_salt('bf') )
		    , pgp_sym_encrypt(l_real_name,p_userdata_password)
			, p_parent_user_id
			, 'token'
			, 'y'
		) returning user_id into l_user_id  ;
		insert into q_qr_auth_security_log ( user_id, activity, location ) values ( l_user_id, 'User Registered', 'File:001.tables.m4.sql Line No:2063');
	end if;

	if not l_fail then
		l_data = '{"status":"success"'
			||', "user_id":' ||coalesce(to_json(l_user_id)::text,'""')
			||', "login_token":' ||coalesce(to_json(l_un)::text,'""')
			||'}';
	end if;

	RETURN l_data;
END;
$$ LANGUAGE plpgsql;






